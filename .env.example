# Backend (Railway) uchun environment variables.
# Railway loyihasining "Variables" bo'limida shu qiymatlarni sozlang.

# /recommend endpoint'idagi tushuntirish uchun (ixtiyoriy — bo'lmasa oddiy
# ro'yxat qaytadi, xato bermaydi).
OPENAI_API_KEY=

# Netlify'dagi frontend production domeni (vergul bilan bir nechtasi
# mumkin). Masalan: https://your-site.netlify.app
ALLOWED_ORIGINS=

# Scraperlar necha soatda bir marta avtomatik ishga tushishi (ixtiyoriy,
# standart 24).
SCRAPE_INTERVAL_HOURS=24
